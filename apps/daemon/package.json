{
  "name": "@observer-os/daemon",
  "version": "1.1.1",
  "description": "Observer OS daemon — REST API + WebSocket + Explorer UI",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "observer-daemon": "./dist/index.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build",
    "build:ui": "pnpm --filter @observer-os/explorer build && mkdir -p public && cp -r ../explorer/dist/. public/",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "prepack": "pnpm build:ui && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist public *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.0",
    "@observer-os/ai-query": "workspace:*",
    "@observer-os/plugin-cdp": "workspace:*",
    "@observer-os/context-engine": "workspace:*",
    "@observer-os/core": "workspace:*",
    "@observer-os/plugin-browser": "workspace:*",
    "@observer-os/sdk": "workspace:*",
    "fastify": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "ws": "^8.0.0"
  }
}
