{
  "name": "@observer-os/cli",
  "version": "1.1.0",
  "description": "Observer OS CLI — interact with the daemon from any terminal",
  "files": [
    "dist"
  ],
  "type": "module",
  "bin": {
    "observer": "./dist/bin.js"
  },
  "main": "./dist/index.js",
