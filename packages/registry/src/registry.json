{
  "schemaVersion": "1.0",
  "updatedAt": "2026-06-30",
  "plugins": [
    {
      "id": "plugin-browser",
      "name": "@observer-os/plugin-browser",
      "displayName": "Browser Observer",
      "description": "Instruments browser fetch, XHR, console, DOM errors, and navigation events. Injects into any web page.",
      "category": "frontend",
      "tags": ["browser", "fetch", "xhr", "console", "dom", "navigation"],
      "version": "1.0.0",
      "verified": true,
      "firstParty": true,
      "homepage": "https://github.com/observer-os/observer",
      "runtimes": ["browser"],
      "nodeTypes": ["observer.browser/fetch", "observer.browser/xhr", "observer.browser/console", "observer.browser/dom-error", "observer.browser/navigation"]
    },
    {
      "id": "plugin-express",
      "name": "@observer-os/plugin-express",
      "displayName": "Express Observer",
      "description": "Instruments Express.js HTTP requests, responses, and errors. Extracts W3C trace context for cross-domain correlation.",
      "category": "backend",
      "tags": ["express", "http", "node", "middleware"],
      "version": "1.0.0",
      "verified": true,
      "firstParty": true,
      "homepage": "https://github.com/observer-os/observer",
      "runtimes": ["node"],
      "nodeTypes": ["observer.express/request", "observer.express/response", "observer.express/error"]
    },
    {
      "id": "plugin-postgres",
      "name": "@observer-os/plugin-postgres",
      "displayName": "PostgreSQL Observer",
      "description": "Instruments node-postgres (pg) pool and client queries, transactions, and connection events.",
      "category": "database",
      "tags": ["postgres", "postgresql", "sql", "database", "pg"],
      "version": "1.0.0",
      "verified": true,
      "firstParty": true,
      "homepage": "https://github.com/observer-os/observer",
      "runtimes": ["node"],
      "nodeTypes": ["observer.postgres/query", "observer.postgres/transaction", "observer.postgres/connection"]
    },
    {
      "id": "plugin-react",
      "name": "@observer-os/plugin-react",
      "displayName": "React Observer",
      "description": "Instruments React component renders, state changes, and hooks via the React DevTools global hook. No React import required.",
      "category": "frontend",
      "tags": ["react", "components", "hooks", "state", "renders"],
      "version": "1.0.0",
      "verified": true,
      "firstParty": true,
      "homepage": "https://github.com/observer-os/observer",
      "runtimes": ["browser", "node"],
      "nodeTypes": ["observer.react/component"]
    },
    {
      "id": "plugin-redis",
      "name": "@observer-os/plugin-redis",
      "displayName": "Redis Observer",
      "description": "Instruments ioredis and node-redis clients. Tracks individual commands and pipeline/multi-exec batches.",
      "category": "database",
      "tags": ["redis", "cache", "ioredis", "node-redis", "pipeline"],
      "version": "1.0.0",
      "verified": true,
      "firstParty": true,
      "homepage": "https://github.com/observer-os/observer",
      "runtimes": ["node"],
      "nodeTypes": ["observer.redis/command", "observer.redis/pipeline"]
    },
    {
      "id": "plugin-nextjs",
      "name": "@observer-os/plugin-nextjs",
      "displayName": "Next.js Observer",
      "description": "Instruments Next.js fetch (server + client), getServerSideProps, getStaticProps, and edge middleware. Propagates correlation IDs through RSC context.",
      "category": "framework",
      "tags": ["nextjs", "next", "react", "ssr", "rsc", "edge"],
      "version": "1.0.0",
      "verified": true,
      "firstParty": true,
      "homepage": "https://github.com/observer-os/observer",
      "runtimes": ["node", "edge"],
      "nodeTypes": ["observer.nextjs/fetch", "observer.nextjs/gssp", "observer.nextjs/gsp", "observer.nextjs/middleware"]
    },
    {
      "id": "plugin-prisma",
      "name": "@observer-os/plugin-prisma",
      "displayName": "Prisma Observer",
      "description": "Instruments Prisma ORM via $extends. Tracks all model operations with duration and result count. PII-safe: logs argKeys, not values.",
      "category": "database",
      "tags": ["prisma", "orm", "database", "sql", "typescript"],
      "version": "1.0.0",
      "verified": true,
      "firstParty": true,
      "homepage": "https://github.com/observer-os/observer",
      "runtimes": ["node"],
      "nodeTypes": ["observer.prisma/query", "observer.prisma/transaction"]
    },
    {
      "id": "plugin-graphql",
      "name": "@observer-os/plugin-graphql",
      "displayName": "GraphQL Observer",
      "description": "Wraps graphql-js execute function to instrument queries, mutations, and subscriptions. Works with Apollo Server, Yoga, and any graphql-js-based server.",
      "category": "api",
      "tags": ["graphql", "apollo", "yoga", "api", "queries", "mutations"],
      "version": "1.0.0",
      "verified": true,
      "firstParty": true,
      "homepage": "https://github.com/observer-os/observer",
      "runtimes": ["node"],
      "nodeTypes": ["observer.graphql/operation"]
    },
    {
      "id": "plugin-http",
      "name": "@observer-os/plugin-http",
      "displayName": "HTTP Observer",
      "description": "Instruments Node.js http.request and https.request. Covers all HTTP clients that don't use fetch: got, axios, needle, node-fetch, etc.",
      "category": "backend",
      "tags": ["http", "https", "got", "axios", "node-fetch", "request"],
      "version": "1.0.0",
      "verified": true,
      "firstParty": true,
      "homepage": "https://github.com/observer-os/observer",
      "runtimes": ["node"],
      "nodeTypes": ["observer.http/request"]
    }
  ]
}
